# ── Supabase (signaling + presence para multiplayer) ──────────
# 1. Crie projeto gratuito em https://supabase.com
# 2. Project Settings → API → copie as chaves
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ── Sentry (monitoramento de erros — opcional mas recomendado) ─
# 1. Crie projeto em https://sentry.io (free: 5k erros/mês)
# 2. Settings → Client Keys → DSN
VITE_SENTRY_DSN=https://SEU_ID@oXXXXXX.ingest.sentry.io/XXXXXXX

# ── PeerJS (opcional — padrão usa servidor público gratuito) ──
# VITE_PEERJS_HOST=
# VITE_PEERJS_PORT=
# VITE_PEERJS_PATH=
